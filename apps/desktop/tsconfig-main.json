{
  "compilerOptions": {
    "target": "es2022",
    "useDefineForClassFields": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "allowJs": true,
    "noEmitHelpers": true,
    "importHelpers": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "paths": {
      "@horizon/shared/*": ["../../packages/shared/src/*"],
      "@/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["main.ts", "preload.ts", "vite-env.d.ts"]
}
